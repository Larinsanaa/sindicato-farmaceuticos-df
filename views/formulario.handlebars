<div style="max-width:760px;margin:40px auto;font-family:Arial, sans-serif;line-height:1.5;">
    <h1>Bem-vindo ao Sindicato</h1>

    {{#if error}}
    <div style="padding:16px;background:#ffe5e5;border:1px solid #ffb3b3;color:#a40000;margin-bottom:20px;">
        <strong>Erro:</strong> {{error}}
        {{#if details}}<div style="margin-top:8px;font-size:0.95rem;color:#6a0000;">{{details}}</div>{{/if}}
    </div>
    {{/if}}

    {{#if success}}
    <div style="padding:16px;background:#e6ffe6;border:1px solid #9cffa1;color:#116611;margin-bottom:20px;">
        <strong>Sucesso:</strong> {{success}}
    </div>
    {{/if}}

    {{#if token}}
    <div style="padding:16px;background:#f0f7ff;border:1px solid #a9c9ff;color:#154a9a;margin-bottom:20px;">
        <strong>Token JWT:</strong>
        <pre style="white-space:pre-wrap;word-break:break-all;background:#fff;padding:12px;border:1px solid #d0d7eb;border-radius:4px;margin-top:8px;">{{token}}</pre>
    </div>
    {{/if}}

    <div style="border:1px solid #ddd;border-radius:10px;overflow:hidden;box-shadow:0 2px 8px rgba(0,0,0,0.04);">
        <div style="display:flex;background:#f7f7f7;">
            <button id="tab-login" type="button" style="flex:1;padding:16px;border:none;background:transparent;cursor:pointer;font-size:1rem;font-weight:bold;" class="tab-button">Login</button>
            <button id="tab-register" type="button" style="flex:1;padding:16px;border:none;background:transparent;cursor:pointer;font-size:1rem;font-weight:bold;" class="tab-button">Cadastro</button>
        </div>
        <div id="panel-login" style="padding:24px;background:#fff;display:none;">
            <h2>Login</h2>
            <form action="/login" method="POST">
                <label style="display:block;margin-bottom:12px;">
                    Email<br>
                    <input type="email" name="email" value="{{email}}" style="width:100%;padding:10px;border:1px solid #ccc;border-radius:6px;" required>
                </label>
                <label style="display:block;margin-bottom:16px;">
                    Senha<br>
                    <input type="password" name="senha" style="width:100%;padding:10px;border:1px solid #ccc;border-radius:6px;" required>
                </label>
                <button type="submit" style="display:inline-block;padding:12px 20px;background:#0070f3;color:#fff;border:none;border-radius:8px;cursor:pointer;">Entrar</button>
            </form>
        </div>
        <div id="panel-register" style="padding:24px;background:#fff;display:none;">
            <h2>Cadastro</h2>
            <form action="/cadastro" method="POST">
                <label style="display:block;margin-bottom:12px;">
                    Nome<br>
                    <input type="text" name="nome" value="{{nome}}" style="width:100%;padding:10px;border:1px solid #ccc;border-radius:6px;" required>
                </label>
                <label style="display:block;margin-bottom:12px;">
                    Email<br>
                    <input type="email" name="email" value="{{email}}" style="width:100%;padding:10px;border:1px solid #ccc;border-radius:6px;" required>
                </label>
                <label style="display:block;margin-bottom:16px;">
                    Senha<br>
                    <input type="password" name="senha" style="width:100%;padding:10px;border:1px solid #ccc;border-radius:6px;" required>
                </label>
                <button type="submit" style="display:inline-block;padding:12px 20px;background:#0070f3;color:#fff;border:none;border-radius:8px;cursor:pointer;">Cadastrar</button>
            </form>
        </div>
    </div>
</div>

<script>
(function() {
    const active = '{{form}}' || 'login';
    const loginTab = document.getElementById('tab-login');
    const registerTab = document.getElementById('tab-register');
    const loginPanel = document.getElementById('panel-login');
    const registerPanel = document.getElementById('panel-register');

    function setActive(tab) {
        if (tab === 'register') {
            loginPanel.style.display = 'none';
            registerPanel.style.display = 'block';
            loginTab.style.background = 'transparent';
            registerTab.style.background = '#fff';
        } else {
            loginPanel.style.display = 'block';
            registerPanel.style.display = 'none';
            loginTab.style.background = '#fff';
            registerTab.style.background = 'transparent';
        }
    }

    loginTab.addEventListener('click', () => setActive('login'));
    registerTab.addEventListener('click', () => setActive('register'));

    setActive(active === 'cadastro' ? 'register' : 'login');
})();
</script>